# EditorConfig: https://editorconfig.org
# Strategy:
#   - IntelliJ code style XML (intellij-java-google-style.xml) is kept as STOCK Google Style.
#     It governs structural rules: brace style, operator wrap, import order, Javadoc format, etc.
#   - This .editorconfig file overrides ONLY the two project-specific deviations from Google defaults
#     that IntelliJ respects via EditorConfig (indent_size, max_line_length) for Java.
#   - geojson4j_checks.xml and rewrite.yml enforce and auto-fix the same Java values below.

root = true

# Defaults for all files (Google style baseline: 2-space)
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Java – project override: 4-space indent, 160-char line limit
# These two values deviate from stock Google Style (2-space / 100-char) intentionally.
# IntelliJ picks these up via EditorConfig and applies them on top of the Google XML scheme.
# Checkstyle (geojson4j_checks.xml) and OpenRewrite (rewrite.yml) enforce the same values.
[*.java]
indent_style = space
indent_size = 4
max_line_length = 160

# ── IntelliJ-specific overrides (ij_java_*) ─────────────────────────────────
# Applied on top of the stock Google XML scheme. Ignored by other editors.

# Code continuation indent: override stock Google XML CONTINUATION_INDENT_SIZE=4 → 8
# Matches geojson4j_checks.xml Indentation.lineWrappingIndentation = 8
ij_java_continuation_indent_size = 8

# ── Javadoc settings – aligned with geojson4j_checks.xml Javadoc rules ───────
# ij_java_wrap_comments = false
#   Stops IntelliJ from reflowing Javadoc text at the right margin.
#   OpenRewrite AutoFormat also never reflows comment text → both tools agree.
ij_java_wrap_comments = false

# Keep /** short comment */ on a single line → SingleLineJavadoc check
ij_java_doc_do_not_wrap_if_one_line_comment = true

# Blank line between description and first @param block → RequireEmptyLineBeforeBlockTagGroup
ij_java_doc_add_blank_after_description = true

# Do NOT insert <p> tag at empty lines inside Javadoc → JavadocParagraph (allowNewlineParagraph=false)
ij_java_doc_p_at_empty_lines = false

# No column-alignment of @param / @throws descriptions → avoids artificial whitespace Checkstyle flags
ij_java_doc_align_param_comments = false
ij_java_doc_align_exception_comments = false

# Strip empty @param / @throws / @return tags → NonEmptyAtclauseDescription
ij_java_doc_keep_empty_parameter = false
ij_java_doc_keep_empty_exception = false
ij_java_doc_keep_empty_return = false

# XML / Maven POM – keep at 2-space (matches IntelliJ Google XML XML section)
[*.xml]
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Markdown – allow long lines (URLs, tables)
[*.md]
trim_trailing_whitespace = false
max_line_length = off
